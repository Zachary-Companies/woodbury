{
  "name": "@zachary/woodbury",
  "productName": "Woodbury",
  "version": "1.2.2",
  "description": "Interactive AI coding assistant",
  "main": "dist/index.js",
  "bin": {
    "woodbury": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs');if(process.platform!=='win32'){try{fs.chmodSync('dist/index.js',0o755)}catch{}};fs.cpSync('src/config-dashboard','dist/config-dashboard',{recursive:true,force:true})\"",
    "clean": "rimraf dist",
    "watch": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "publish:patch": "npm version patch && npm publish",
    "all": "npm run clean && npm run build && npm test && npm run commit && npm run publish:patch",
    "commit": "git add . && git commit -m \"Auto-update\" || true",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "postinstall": "node -e \"if(process.platform==='darwin'){try{require('child_process').execSync('plutil -replace CFBundleDisplayName -string Woodbury node_modules/electron/dist/Electron.app/Contents/Info.plist 2>/dev/null; plutil -replace CFBundleName -string Woodbury node_modules/electron/dist/Electron.app/Contents/Info.plist 2>/dev/null; true')}catch{}}\"",
    "electron:dev": "npm run build && electron electron/main.js",
    "electron:build": "npm run build && electron-builder --mac",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:pack": "npm run build && electron-builder --mac --dir",
    "deploy:web": "npm run build && cd apps/woodbury-web && npm run build && npx firebase deploy --only hosting",
    "deploy:all": "npm run build && cd apps/woodbury-web && npm run build && npx firebase deploy --only hosting,firestore && cd ../.. && electron-builder --mac --arm64 --dir"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.77.0",
    "@types/ws": "^8.18.1",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "commander": "^11.1.0",
    "electron-updater": "^6.8.3",
    "firebase": "^12.9.0",
    "flow-frame-core": "^0.1.11",
    "groq-sdk": "^0.37.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "onnxruntime-node": "^1.24.2",
    "openai": "^6.22.0",
    "ora": "^9.1.0",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^24.37.4",
    "sharp": "^0.33.5",
    "uiohook-napi": "^1.5.4",
    "ws": "^8.19.0",
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/qs": "^6.14.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "optionalDependencies": {
    "canvas": "^3.2.0"
  },
  "keywords": [
    "ai",
    "coding",
    "assistant",
    "cli"
  ],
  "author": "Zachary Companies",
  "license": "MIT"
}
