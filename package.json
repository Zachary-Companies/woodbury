{
  "name": "@zachary/woodbury",
  "version": "1.0.11",
  "description": "Interactive AI coding assistant",
  "main": "dist/index.js",
  "bin": {
    "woodbury": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js && rm -rf dist/config-dashboard && cp -r src/config-dashboard dist/config-dashboard",
    "clean": "rimraf dist",
    "watch": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "publish:patch": "npm version patch && npm publish",
    "all": "npm run clean && npm run build && npm test && npm run commit && npm run publish:patch",
    "commit": "git add . && git commit -m \"Auto-update\" || true",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.77.0",
    "@types/ws": "^8.18.1",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "commander": "^11.1.0",
    "flow-frame-core": "^0.1.7",
    "groq-sdk": "^0.37.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "openai": "^6.22.0",
    "ora": "^9.1.0",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^24.37.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/qs": "^6.14.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "ai",
    "coding",
    "assistant",
    "cli"
  ],
  "author": "Zachary Companies",
  "license": "MIT"
}
