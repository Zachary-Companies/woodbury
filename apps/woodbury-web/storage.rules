rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Workflow packages: public read, authenticated owner write
    match /workflows/{userId}/{workflowId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Model files: public read, authenticated owner write
    match /models/{userId}/{workflowId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // User avatars: public read, owner write
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Workflow screenshots: public read, owner write
    match /screenshots/{userId}/{workflowId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
