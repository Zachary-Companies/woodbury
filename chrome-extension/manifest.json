{
  "manifest_version": 3,
  "name": "Woodbury Bridge",
  "version": "1.0.0",
  "description": "Connects Chrome to the Woodbury desktop app for browser automation. Record, replay, and debug workflows.",
  "homepage_url": "https://github.com/Zachary-Companies/woodbury",
  "offline_enabled": false,
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "alarms",
    "debugger",
    "sidePanel",
    "storage",
    "downloads"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "toggle-sidepanel": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Toggle the Woodbury debug side panel"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
